if (isset($_POST['submit'])) {  // Check if the form is submitted
    // Sanitize inputs
    $name = sanitize_text_field($_POST['user_name']);
    $email = sanitize_email($_POST['user_email']);
    $roll = sanitize_text_field($_POST['roll']);
    
    // Define the list of email addresses (Admin email + Additional emails)
    $email_list = array(
        get_option('admin_email'),         // Admin email (can be fetched from WordPress settings)
        'mdsablu36@gamil.com',             // Additional email
        'another_email@example.com',       // Add more emails as needed
        'someone_else@example.com',        // Another additional email
    );

    // Subject and Body of the email
    $subject = "New Name Submission";
    $body = "A new name has been submitted:\n\nName: $name\nEmail: $email \n";
    $body .= "Roll: $roll\n";

    // Email headers
    $headers = array('Content-Type: text/plain; charset=UTF-8');
    $headers[] = 'From: ' . $name . ' <' . $email . '>';

    // Send email to all recipients in the array
    $sent = wp_mail($email_list, $subject, $body, $headers);

    // Display success or error message
    if ($sent) {
        echo "<p>Thank you! Your submission has been sent successfully.</p>";
        header("Refresh: 4; url=" . $_SERVER['REQUEST_URI']);  // Redirect to the same page after 2 seconds
        exit; // Ensure that script stops here after redirection
    } else {
        echo "<p>Error sending your submission. Please try again.</p>";
    }
}
?>
