<script>

function loadProducts(){

    let formData = new FormData();

    formData.append(
        'action',
        'product_search'
    );

    formData.append(
        'title',
        document.getElementById('title').value
    );

    formData.append(
        'price',
        document.getElementById('price').value
    );

    formData.append(
        'data1',
        document.getElementById('data1').value
    );

    fetch(
        '<?php echo admin_url('admin-ajax.php'); ?>',
        {
            method:'POST',
            body:formData
        }
    )
    .then(res => res.text())
    .then(html => {

        document.getElementById('products').innerHTML = html;

    });

}

loadProducts();

document
.getElementById('title')
.addEventListener('keyup',loadProducts);

document
.getElementById('price')
.addEventListener('keyup',loadProducts);

document
.getElementById('data1')
.addEventListener('keyup',loadProducts);

</script>




// filter area 
add_action('wp_ajax_product_search','product_search_callback');

add_action('wp_ajax_nopriv_product_search','product_search_callback');

function product_search_callback(){

    $title = sanitize_text_field($_POST['title'] ?? '');
    $price = sanitize_text_field($_POST['price'] ?? '');
    $data1 = sanitize_text_field($_POST['data1'] ?? '');

    $args = [
        'post_type'      => 'product',
        'post_status'    => 'publish',
        'posts_per_page' => 12,
        'meta_query'     => []
    ];

    if($title){
        $args['s'] = $title;
    }

    if($price){
        $args['meta_query'][] = [
            'key'     => '_price',
            'value'   => $price,
            'compare' => '='
        ];
    }

    if($data1){
        $args['meta_query'][] = [
            'key'     => 'data1',
            'value'   => $data1,
            'compare' => 'LIKE'
        ];
    }

    $query = new WP_Query($args);
    if($query->have_posts()){
        echo '<div class="products-grid">';

        while($query->have_posts()){
            $query->the_post();
            $book_data = get_post_meta(
                get_the_ID(),
                'data1',
                true
            );

            $product = wc_get_product(
                get_the_ID()
            );

            ?>

            <div class="product-card">

                <a href="<?php the_permalink(); ?>">
                    <?php
                    if(
                        has_post_thumbnail()
                    ){
                        the_post_thumbnail(
                            'woocommerce_thumbnail'
                        );
                    }
                    ?>

                </a>

                <div class="product-content">
                    <h3><?php the_title(); ?></h3>
                    <div class="product-meta"> <?php echo esc_html($book_data); ?> </div>
                    <div class="product-price"><?php echo $product->get_price_html(); ?> </div>
                    <a href="<?php the_permalink(); ?>" class="product-btn" > View Product  </a>
                </div>

            </div>

            <?php

        }

        echo '</div>';
        wp_reset_postdata();
    }else{
        echo '<h3>No Products Found</h3>';
    }

    wp_die();

}
