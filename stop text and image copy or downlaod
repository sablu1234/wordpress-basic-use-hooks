/**
 * Disable text selection on the website (except for input fields and textareas)
 */
add_action( 'wp_head', 'astra_child_copy_protection_css' );
function astra_child_copy_protection_css() {
    ?>
    <style id="copy-protection-css">
    /* Prevent text selection across the website */
    body {
        -webkit-user-select: none;  /* Safari */
        -moz-user-select: none;     /* Firefox */
        -ms-user-select: none;      /* IE/Edge */
        user-select: none;          /* Standard */
    }

    /* Allow selection in inputs, textareas, and other editable elements for normal UX */
    input, textarea, select, [contenteditable="true"] {
        -webkit-user-select: text;
        -moz-user-select: text;
        -ms-user-select: text;
        user-select: text;
    }
    </style>
    <?php
